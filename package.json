{
  "name": "vite-vue3-template",
  "type": "module",
  "version": "1.0.0",
  "private": true,
  "packageManager": "pnpm@10.29.2",
  "scripts": {
    "dev": "vite --mode development",
    "prod": "vite --mode production",
    "build": "vue-tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "postinstall": "npx simple-git-hooks"
  },
  "dependencies": {
    "axios": "^1.13.5",
    "dayjs": "^1.11.19",
    "pinia": "^3.0.4",
    "vant": "^4.9.22",
    "vue": "^3.5.28",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^5.4.1",
    "@types/node": "^24.10.13",
    "@unocss/eslint-config": "^66.6.0",
    "@vant/auto-import-resolver": "^1.3.0",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vueuse/core": "^13.9.0",
    "cross-env": "^10.1.0",
    "eruda": "^3.4.3",
    "es-toolkit": "^1.44.0",
    "eslint": "^9.39.2",
    "lint-staged": "^16.2.7",
    "postcss-px-to-viewport-8-plugin": "^1.2.5",
    "sass": "^1.97.3",
    "simple-git-hooks": "^2.13.1",
    "typescript": "^5.9.3",
    "unocss": "^66.6.0",
    "unplugin-auto-import": "^20.3.0",
    "unplugin-vue-components": "^29.2.0",
    "vite": "^7.3.1",
    "vue-tsc": "^3.2.4"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
